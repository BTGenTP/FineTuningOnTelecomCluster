<root main_tree_to_execute="real_inspection_mission">
  <BehaviorTree ID="real_inspection_mission">
    <Sequence name="REAL INSPECTION MISSION">
      <SubTreePlus name="REAL PREPARATION" ID="real_preparation" __autoremap="true" />
      <SubTreePlus name="EXECUTE" ID="execute" __autoremap="true" />
    </Sequence>
  </BehaviorTree>
  <BehaviorTree ID="real_preparation">
    <Sequence name="REAL PREPARATION">
      <SubTreePlus name="BASE PREPARATION" ID="base_preparation" __autoremap="true" mission_file="default" adv_path="{adv_path}" mission_sequence="{mission-sequence}" />
      <Condition name="IS ROBOT PROJECTION ACTIVE" ID="IsRobotPoseProjectionActive" adv_path="{adv_path}" pub_proj="true" />
      <Action name="SIGNAL AND WAIT" ID="SignalAndWaitForOrder" message="ready to move - wait for authorization" />
    </Sequence>
  </BehaviorTree>
  <BehaviorTree ID="base_preparation">
    <Sequence name="BASE PREPARATION">
      <SubTreePlus name="GET MISSION" ID="get_mission" __autoremap="true" mission_file_path="{mission_file}" />
      <SubTreePlus name="CALCULATE PATH" ID="calculate_path" __autoremap="true" />
      <Action name="PASS ADVANCED PATH" ID="PassAdvancedPath" adv_path="{adv_path}" />
      <Action name="PASS MISSION" ID="PassMission" mission="{mission}" />
      <Action name="GENERATE MOTION SEQUENCE" ID="GenerateMissionSequence" mission="{mission}" mission_sequence="{mission_sequence}" />
    </Sequence>
  </BehaviorTree>
  <BehaviorTree ID="get_mission">
    <Sequence name="GET MISSION">
      <Action name="LOAD MISSION" ID="LoadMission" mission_file_path="{mission_file_path}" />
      <Condition name="IS MISSION STRUCTURE VALID" ID="MissionStructureValid" />
    </Sequence>
  </BehaviorTree>
  <BehaviorTree ID="calculate_path">
    <Fallback name="PATH CALCULATION">
      <Repeat name="LOOP" num_cycles="-1">
        <Sequence name="ACTIVITY">
          <Action name="UPDATE CURRENT ACTIVITY" ID="UpdateCurrentGeneratedActivity" type="{type}" origin_sph="{origin_sph}" target_sph="{target_sph}" forbidden_atoms_out="{forbidden_atoms}" />
          <Action name="PROJECT ORIGIN" ID="ProjectPointOnNetwork" point_in="{origin_sph}" point_out="{origin}" />
          <Action name="PROJECT TARGET" ID="ProjectPointOnNetwork" point_in="{target_sph}" point_out="{target}" />
          <Action name="CREATE PATH" ID="CreatePath" origin="{origin}" target="{target}" forbidden_atoms="{forbidden_atoms}" path="{path}" />
          <Action name="AGREGATE PATH" ID="AgregatePath" path="{path}" />
        </Sequence>
      </Repeat>
      <Condition name="MISSION FULLY TREATED" ID="MissionFullyTreated" type="{type}" />
    </Fallback>
  </BehaviorTree>
  <BehaviorTree ID="execute">
    <ReactiveFallback name="EXECUTE">
      <Repeat name="SEQUENCE STEP LOOP" num_cycles="-1">
        <Fallback name="MOTION SELECTOR">
          <SubTreePlus name="MOVE" ID="move" __autoremap="true" />
          <SubTreePlus name="MOVE AND INSPECT" ID="move_and_inspect" __autoremap="true" />
          <SubTreePlus name="DECCELERATE" ID="deccelerate" __autoremap="true" />
          <SubTreePlus name="DECCELERATE AND INSPECT" ID="deccelerate_and_inspect" __autoremap="true" />
          <SubTreePlus name="REACH AND STOP" ID="reach_and_stop" __autoremap="true" />
          <SubTreePlus name="REACH AND STOP INSPECTING" ID="reach_and_stop_inspecting" __autoremap="true" />
          <SubTreePlus name="PASS" ID="pass" __autoremap="true" />
          <SubTreePlus name="PASS AND STOP INSPECTING" ID="pass_and_stop_inspecting" __autoremap="true" />
          <SubTreePlus name="REACH AND STOP WITHOUT WAITING" ID="reach_stop_and_dont_wait" __autoremap="true" />
          <SubTreePlus name="REACH AND STOP INSPECTING WITHOUT WAITING" ID="reach_stop_inspecting_dont_wait" __autoremap="true" />
        </Fallback>
      </Repeat>
      <Condition name="IS MISSION TERMINATED" ID="MissionTerminated" />
    </ReactiveFallback>
  </BehaviorTree>
  <BehaviorTree ID="move">
    <Sequence name="MOVE">
      <Condition name="IS CURRENT STEP MOVE" ID="CheckCurrentStepType" type_to_be_checked="0" />
      <Action name="PASS MOTION PARAMETERS" ID="PassMotionParameters" motion_params="{DataFlowEdge9}" />
      <Action name="MOVE" ID="Move" threshold_type="1" motion_params="{DataFlowEdge9}" />
      <Action name="UPDATE CURRENT STEP" ID="UpdateCurrentExecutedStep" />
    </Sequence>
  </BehaviorTree>
  <BehaviorTree ID="move_and_inspect">
    <Sequence name="MOVE AND INSPECT">
      <Condition name="IS CURRENT STEP MOVE AND INSPECT" ID="CheckCurrentStepType" type_to_be_checked="10" />
      <Action name="PASS MOTION PARAMETERS" ID="PassMotionParameters" motion_params="{motion_params}" />
      <Action name="PAUSE" ID="Pause" duration="2.0" />
      <Action name="START INSPECTION" ID="ManageMeasurements" />
      <Action name="MOVE" ID="Move" threshold_type="1" motion_params="{motion_params}" />
      <Action name="UPDATE CURRENT STEP" ID="UpdateCurrentExecutedStep" />
    </Sequence>
  </BehaviorTree>
  <BehaviorTree ID="deccelerate">
    <Sequence name="DECCELERATE">
      <Condition name="IS CURRENT STEP DECCELERATE" ID="CheckCurrentStepType" type_to_be_checked="1" />
      <Action name="PASS MOTION PARAMETERS" ID="PassMotionParameters" motion_params="{motion_params}" />
      <Action name="DECCELERATE" ID="Deccelerate" motion_params="{motion_params}" />
      <Action name="UPDATE CURRENT STEP" ID="UpdateCurrentExecutedStep" />
    </Sequence>
  </BehaviorTree>
  <BehaviorTree ID="deccelerate_and_inspect">
    <Sequence name="DECCELERATE AND INSPECT">
      <Condition name="IS CURRENT STEP DECCELERATE AND INSPECT" ID="CheckCurrentStepType" type_to_be_checked="11" />
      <Action name="PASS MOTION PARAMETERS" ID="PassMotionParameters" motion_params="{motion_params}" />
      <Action name="DECCELERATE" ID="Deccelerate" motion_params="{motion_params}" />
      <Action name="UPDATE CURRENT STEP" ID="UpdateCurrentExecutedStep" />
    </Sequence>
  </BehaviorTree>
  <BehaviorTree ID="reach_and_stop">
    <Sequence name="REACH AND STOP">
      <Condition name="IS CURRENT STEP REACH AND STOP" ID="CheckCurrentStepType" type_to_be_checked="2" />
      <Action name="PASS MOTION PARAMETERS" ID="PassMotionParameters" motion_params="{motion_params}" />
      <Action name="MOVE AND STOP" ID="MoveAndStop" motion_params="{motion_params}" />
      <Action name="SIGNAL AND WAIT FOR AUTHORIZATION" ID="SignalAndWaitForOrder" message="need authorization to go further" />
      <Action name="UPDATE CURRENT STEP" ID="UpdateCurrentExecutedStep" />
    </Sequence>
  </BehaviorTree>
  <BehaviorTree ID="reach_and_stop_inspecting">
    <Sequence name="REACH AND STOP INSPECTIONG">
      <Condition name="IS CURRENT STEP REACH AND STOP INSPECTING" ID="CheckCurrentStepType" type_to_be_checked="12" />
      <Action name="PASS MOTION PARAMETERS" ID="PassMotionParameters" motion_params="{DataFlowEdge9}" />
      <Action name="MOVE AND STOP" ID="MoveAndStop" motion_params="{DataFlowEdge9}" />
      <Action name="STOP INSPECTION" ID="ManageMeasurements" />
      <Action name="ANALYSE MEASUREMENTS" ID="AnalyseMeasurements" />
      <Sequence name="REACT ON QUALITY">
        <Fallback name="CORRECTIVE SEQUENCE">
          <Condition name="IS MEASUREMENT QUALITY OK" ID="MeasurementsQualityValidated" />
          <Action name="PASS DEFECTS LOCALIZATION" ID="PassDefectsLocalization" defects="{defects}" />
        </Fallback>
        <Action name="GENERATE CORRECTIVE SEQUENCE" ID="GenerateCorrectiveSubSequence" defects="{defects}" />
        <Action name="INSERT CORRECTIVE SEQUENCE" ID="InsertCorrectiveSubSequence" />
      </Sequence>
      <Action name="UPDATE CURRENT STEP" ID="UpdateCurrentExecutedStep" />
    </Sequence>
  </BehaviorTree>
  <BehaviorTree ID="pass">
    <Sequence name="PASS">
      <Condition name="IS CURRENT STEP PASS" ID="CheckCurrentStepType" type_to_be_checked="3" />
      <Action name="PASS MOTION PARAMETERS" ID="PassMotionParameters" motion_params="{motion_params}" />
      <Action name="MOVE" ID="Move" threshold_type="3" motion_params="{motion_params}" />
      <Action name="UPDATE CURRENT STEP" ID="UpdateCurrentExecutedStep" />
    </Sequence>
  </BehaviorTree>
  <BehaviorTree ID="pass_and_stop_inspecting">
    <Sequence name="PASS AND STOP INSPECTING">
      <Condition name="IS CURRENT STEP PASS AND STOP INSPECTING" ID="CheckCurrentStepType" type_to_be_checked="13" />
      <Action name="PASS MOTION PARAMETERS" ID="PassMotionParameters" motion_params="{motion_params}" />
      <Action name="MOVE" ID="Move" threshold_type="3" motion_params="{motion_params}" />
      <Action name="STOP INSPECTION" ID="ManageMeasurements" />
      <Fallback name="ENFORCED ANALYSIS">
        <Action name="ANALYSE MEASUREMENTS" ID="AnalyseMeasurements" />
        <Condition name="ENFORCED VALIDATION" ID="MeasurementsEnforcedValidated" />
      </Fallback>
      <Action name="UPDATE CURRENT STEP" ID="UpdateCurrentExecutedStep" />
    </Sequence>
  </BehaviorTree>
  <BehaviorTree ID="reach_stop_and_dont_wait">
    <Sequence name="REACH STOP and DONT WAIT">
      <Condition name="IS CURRENT STEP REACH STOP and DONT WAIT" ID="CheckCurrentStepType" type_to_be_checked="4" />
      <Action name="PASS MOTION PARAMETERS" ID="PassMotionParameters" motion_params="{motion_params}" />
      <Action name="MOVE AND STOP" ID="MoveAndStop" motion_params="{motion_params}" />
      <Action name="UPDATE CURRENT STEP" ID="UpdateCurrentExecutedStep" />
    </Sequence>
  </BehaviorTree>
  <BehaviorTree ID="reach_stop_inspecting_dont_wait">
    <Sequence name="REACH AND STOP INSPECTING DONT WAIT">
      <Condition name="IS CURRENT STEP REACH AND STOP INSPECTING DONT WAIT" ID="CheckCurrentStepType" type_to_be_checked="14" />
      <Action name="PASS MOTION PARAMETERS" ID="PassMotionParameters" motion_params="{motion_params}" />
      <Action name="MOVE AND STOP" ID="MoveAndStop" motion_params="{motion_params}" />
      <Action name="STOP INSPECTION" ID="ManageMeasurements" />
      <Action name="ANALYSE MEASUREMENTS" ID="AnalyseMeasurements" />
      <Fallback name="CORRECTIVE SEQUENCE">
        <Condition name="IS MEASUREMENTS QUALITY OK" ID="MeasurementsQualityValidated" />
        <Sequence name="REACT ON MEASUREMENTS QUALTY">
          <Action name="PASS DEFECTS LOCALIZATION" ID="PassDefectsLocalization" defects="{defects}" />
          <Action name="GENERATE CORRECTIVE SEQUENCE" ID="GenerateCorrectiveSubSequence" defects="{defects}" />
          <Action name="INSERT CORRECTIVE SEQUENCE" ID="InsertCorrectiveSubSequence" />
        </Sequence>
      </Fallback>
      <Action name="UPDATE CURRENT STEP" ID="UpdateCurrentExecutedStep" />
    </Sequence>
  </BehaviorTree>
</root>
